# Copy this file to `.env` and fill in only the variables you need.
# Root `.env` is loaded first by the public release scripts.

# -----------------------------------------------------------------------------
# Shared runtime
# -----------------------------------------------------------------------------
# These cache paths help suppress matplotlib/fontconfig warnings during local runs.
XDG_CACHE_HOME=.cache
MPLCONFIGDIR=.cache/matplotlib

# -----------------------------------------------------------------------------
# Terminal agents
# -----------------------------------------------------------------------------
# Gemini terminal agent (`agent/gemini.py`)
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# Azure OpenAI terminal agent (`agent/chatgpt.py`)
CHATGPT_AZURE_OPENAI_API_KEY=
CHATGPT_AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/openai/responses?api-version=2025-04-01-preview
AZURE_OPENAI_DEPLOYMENT=gpt-5.2
AZURE_OPENAI_API_VERSION=2025-04-01-preview

# Anthropic terminal agent (`agent/claude.py`)
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-5-20250929
ANTHROPIC_API_URL=https://api.anthropic.com/v1/messages

# OpenAI-compatible / vLLM terminal agent (`agent/vllm.py`)
OPENAI_API_URL=http://127.0.0.1:8000/v1
OPENAI_API_BASE=http://127.0.0.1:8000/v1
VLLM_API_URL=http://127.0.0.1:8000/v1
OPENAI_API_KEY=EMPTY
VLLM_API_KEY=EMPTY
OPENAI_MODEL=Qwen/Qwen2.5-VL-7B-Instruct

# -----------------------------------------------------------------------------
# HippoCamp RAG / search-agent pipeline
# -----------------------------------------------------------------------------
# Gemini generation for `HippoCamp/scripts/run_query.py`
# You can reuse the same Google key as `GOOGLE_API_KEY` if desired.
GEMINI_API_KEY=your_google_api_key_here

# Embedding / reranking backends
COHERE_API_KEY=
DEEPINFRA_EMBEDDING_API_KEY=
DEEPINFRA_RERANK_API_KEY=

# Vector database
VECTOR_DB_ENDPOINT=
VECTOR_DB_API_KEY=
QDRANT_URL=http://127.0.0.1:6333
QDRANT_API_KEY=
QDRANT_PATH=

# Optional local service ports / endpoints
VLM_PORT=8004
EMBEDDING_PORT=8005
RERANK_PORT=8006
LLM_PORT=8007

# Optional local profiling backend
MONGODB_URI=

# -----------------------------------------------------------------------------
# Evaluation / LLM judge
# -----------------------------------------------------------------------------
# Used by `evaluate.py` and `HippoCamp/scripts/run_evaluation.py`
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/openai/deployments/your-judge-deployment/chat/completions?api-version=2025-01-01-preview

# Optional aliases supported by the evaluation code
GPT4O_MINI_API=
GPT4O_MINI_KEY=

# Optional Azure settings used by service configs
TOOLS_LLM_API_KEY=
TOOLS_LLM_ENDPOINT=
TOOLS_LLM_API_VERSION=2024-02-15-preview
